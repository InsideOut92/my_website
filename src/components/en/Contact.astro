---
import { profile } from "../../data/profile";
const cvMailHref =
  `mailto:${profile.email}?subject=CV%20Request%20and%20Profile&body=Hello%20Patrick%2C%0A%0AI%20am%20interested%20in%20your%20profile%20and%20would%20like%20to%20request%20your%20CV.%0A`;
---
<section class="section contact-section" id="contact-overview-en">
  <h2>Contact</h2>
  <p>
    If you are planning an integration or modernization initiative, we can align on scope, risks,
    and a realistic delivery approach in an initial call.
  </p>
  <div class="cta-row">
    <a class="btn btn-primary" href="mailto:Softwareentwickler@tutamail.com">Send E-Mail</a>
    <a class="btn btn-secondary" href={cvMailHref}>Request CV</a>
    {profile.linkedinUrl && <a class="text-link" href={profile.linkedinUrl} target="_blank" rel="noopener noreferrer">LinkedIn Profile</a>}
  </div>

  <div class="grid grid-2">
    <article class="card">
      <h3>Direct Contact</h3>
      <p>E-Mail: <a href="mailto:Softwareentwickler@tutamail.com">Softwareentwickler@tutamail.com</a></p>
      <p class="muted">Typical response time: 1-2 business days.</p>
    </article>

    <article class="card">
      <h3>Delivery Model</h3>
      <p>Remote or hybrid execution with transparent milestones and clearly prioritized work packages.</p>
      <p class="muted">Primary focus: maintainable implementation and production-grade reliability.</p>
    </article>
  </div>
</section>
