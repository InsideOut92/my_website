---
import { additionalProjectsEn, selectedProjectsEn } from '../../data/projects';
---
<section class="section">
  <h2>Selected Projects</h2>

  <div class="grid grid-2 project-grid">
    {
      selectedProjectsEn.map((project) => (
        <article class="card project-card">
          <h3>{project.title}</h3>
          <p class="muted">{project.subtitle}</p>
          <div class="project-facts">
            {project.facts.map((fact) => (
              <p>
                <strong>{fact.label}</strong>
                <span>{fact.text}</span>
              </p>
            ))}
          </div>
        </article>
      ))
    }
  </div>
</section>

<section class="section">
  <div class="section-head">
    <h2>Additional Project Experience</h2>
  </div>
  <div class="grid grid-2 project-grid">
    {
      additionalProjectsEn.map((project) => (
        <article class="card project-compact">
          <h3>{project.title}</h3>
          <p class="muted">{project.subtitle}</p>
        </article>
      ))
    }
  </div>
</section>

<section class="section">
  <div class="notice">
    <p>
      Client names and internal metrics are intentionally omitted due to confidentiality constraints.
      On request, I can share anonymized flow examples and architecture sketches to discuss the technical approach.
    </p>
  </div>
</section>

<section class="section">
  <div class="notice">
    <p>
      Planning a similar initiative? A short project outline by email is enough for an initial
      technical assessment.
      <a href="/en/contact/">Get in touch</a>
    </p>
  </div>
</section>
