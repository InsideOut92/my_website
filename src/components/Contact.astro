---
import { profile } from "../data/profile";
const cvMailHref =
  `mailto:${profile.email}?subject=Anfrage%20Lebenslauf%20und%20Profil&body=Hallo%20Patrick%2C%0A%0Aich%20interessiere%20mich%20f%C3%BCr%20dein%20Profil%20und%20w%C3%BCrde%20mich%20%C3%BCber%20deinen%20Lebenslauf%20freuen.%0A`;
const primaryMailHref = `mailto:${profile.email}`;
---
<section class="section contact-section" id="contact-overview">
  <h2>Kontakt</h2>
  <p>
    Wenn Sie ein Integrations- oder Modernisierungsvorhaben planen, können wir Anforderungen,
    Risiken und einen realistischen Umsetzungsrahmen in einem Erstgespräch klären.
  </p>
  <div class="cta-row">
    <a class="btn btn-primary" href={primaryMailHref}>E-Mail senden</a>
    <a class="btn btn-secondary" href={cvMailHref}>Lebenslauf anfragen</a>
    {profile.linkedinUrl && <a class="text-link" href={profile.linkedinUrl} target="_blank" rel="noopener noreferrer">LinkedIn Profil</a>}
  </div>

  <div class="grid grid-2">
    <article class="card">
      <h3>Direkter Kontakt</h3>
      <p>E-Mail: <a href={primaryMailHref}>{profile.email}</a></p>
      <p class="muted">Rückmeldung in der Regel innerhalb von 1-2 Werktagen.</p>
    </article>

    <article class="card">
      <h3>Projektmodus</h3>
      <p>Remote oder hybrid, mit transparenten Zwischenständen und klar priorisierten Arbeitspaketen.</p>
      <p class="muted">Fokus auf wartbare Lösungen und stabile Produktionsreife.</p>
    </article>
  </div>
</section>
