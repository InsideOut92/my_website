---
import { additionalProjectsDe, selectedProjectsDe } from '../data/projects';
---

<section class="section">
  <div class="section-head">
    <h2>Ausgewählte Projekte</h2>
    <a class="text-link" href="/projekte/">Vollständige Projektübersicht</a>
  </div>
  <div class="grid grid-2 project-grid">
    {
      selectedProjectsDe.map((project) => (
        <article class="card project-card">
          <h3>{project.title}</h3>
          <p class="muted">{project.subtitle}</p>
          <div class="project-facts">
            {project.facts.map((fact) => (
              <p>
                <strong>{fact.label}</strong>
                <span>{fact.text}</span>
              </p>
            ))}
          </div>
          {
            project.metrics && (
              <div class="project-metrics" aria-label="Orientierungswerte">
                {project.metrics.map((metric) => (
                  <p>
                    <strong>{metric.label}</strong>
                    <span>{metric.value}</span>
                    <small>{metric.note}</small>
                  </p>
                ))}
              </div>
            )
          }
        </article>
      ))
    }
  </div>
</section>

<section class="section">
  <div class="section-head">
    <h2>Weitere Projekterfahrung</h2>
  </div>
  <div class="grid grid-2 project-grid">
    {
      additionalProjectsDe.map((project) => (
        <article class="card project-compact">
          <h3>{project.title}</h3>
          <p class="muted">{project.subtitle}</p>
        </article>
      ))
    }
  </div>
</section>

<section class="section">
  <div class="notice">
    <p>
      Aus Vertraulichkeitsgründen nenne ich keine Kundennamen oder internen Kennzahlen.
      Auf Anfrage teile ich den technischen Ansatz mit anonymisierten Ablaufbeispielen und
      Architektur-Skizzen.
    </p>
  </div>
</section>

<section class="section">
  <div class="notice">
    <p>
      Sie planen ein ähnliches Vorhaben? Eine kurze Projektbeschreibung per E-Mail reicht für
      eine erste fachliche Einschätzung.
      <a href="/kontakt/">Kontakt aufnehmen</a>
    </p>
  </div>
</section>
