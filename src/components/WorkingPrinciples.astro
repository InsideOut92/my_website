<section class="section" aria-labelledby="working-principles-heading">
  <h2 id="working-principles-heading">Zusammenarbeit</h2>
  <div class="grid grid-3">
    <article class="card">
      <h3>Klare Absprachen</h3>
      <p>
        Anforderungen und Prioritäten werden vor der Umsetzung konkretisiert, damit Aufwand und
        Ergebnis planbar bleiben.
      </p>
    </article>
    <article class="card">
      <h3>Transparente Umsetzung</h3>
      <p>
        Zwischenstände werden nachvollziehbar dokumentiert, inklusive offener Punkte, Risiken und
        nächster Schritte.
      </p>
    </article>
    <article class="card">
      <h3>Stabile Auslieferung</h3>
      <p>
        Fokus auf wartbare Lösungen mit sauberem Fehlerverhalten statt kurzfristiger Einmalfixes.
      </p>
    </article>
  </div>
</section>
