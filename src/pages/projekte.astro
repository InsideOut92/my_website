---
import BaseLayout from '../layouts/BaseLayout.astro';
import Projects from '../components/Projects.astro';
---
<BaseLayout
  title="Projekte"
  description="Praxisnahe Projektbeispiele aus ERP-Anbindung, Datenaufbereitung und Automatisierung mit messbarem Mehrwert im Betrieb."
>
  <main class="page" id="main-content">
    <section class="page-intro">
      <p class="eyebrow">Praxisbeispiele</p>
      <h1>Projekte mit klarem Betriebsnutzen</h1>
      <p class="muted">
        Der Fokus liegt auf stabilen Schnittstellen, nachvollziehbaren Prozessen und planbarer
        Weiterentwicklung im Bestand.
      </p>
    </section>

    <Projects />
  </main>
</BaseLayout>
