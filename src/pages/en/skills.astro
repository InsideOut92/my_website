---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Skills from '../../components/en/Skills.astro';
---
<BaseLayout
  locale="en"
  title="Skills"
  description="Technical focus on Lobster Data integration engineering, API connectivity, data validation, and production-stable operations."
>
  <main class="page" id="main-content">
    <section class="page-intro">
      <p class="eyebrow">Technical Focus</p>
      <h1>Skills for resilient integrations</h1>
      <p class="muted">
        From API integration to data quality: the focus is on production-ready, maintainable
        solutions.
      </p>
    </section>

    <Skills />
  </main>
</BaseLayout>
