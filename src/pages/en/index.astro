---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/en/Hero.astro';
import Skills from '../../components/en/Skills.astro';
import Projects from '../../components/en/Projects.astro';
import Contact from '../../components/en/Contact.astro';
import BlogHighlights from '../../components/en/BlogHighlights.astro';
import ServiceProfile from '../../components/en/ServiceProfile.astro';
import RecruiterSnapshot from '../../components/en/RecruiterSnapshot.astro';
import AboutProfile from '../../components/en/AboutProfile.astro';
import SapTransitionProfile from '../../components/en/SapTransitionProfile.astro';

const structuredData = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Patrick Scharf",
  jobTitle: "Software Developer",
  ...(Astro.site ? { url: Astro.site.toString() } : {}),
  email: "mailto:Softwareentwickler@tutamail.com",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Rimpar",
    addressCountry: "DE"
  },
  knowsAbout: [
    "API Integration",
    "System Interfaces",
    "Data Mapping",
    "Automation",
    "PHP",
    "Python",
    "MySQL"
  ]
};
---
<BaseLayout
  locale="en"
  title="Software Engineering for Integration and Stable Data Workflows"
  description="Integration engineering with Lobster Data, stable data workflows, and a structured transition path toward SAP-adjacent integration roles."
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  <main class="page" id="main-content">
    <Hero />
    <ServiceProfile />
    <Projects />
    <BlogHighlights />
    <AboutProfile />
    <SapTransitionProfile />
    <RecruiterSnapshot />
    <Skills />
    <Contact />
  </main>
</BaseLayout>
