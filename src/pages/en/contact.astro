---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Contact from '../../components/en/Contact.astro';
import WorkingPrinciples from '../../components/en/WorkingPrinciples.astro';
---
<BaseLayout
  locale="en"
  title="Contact"
  description="Contact for integration engineering, Lobster Data projects, and ERP-adjacent technical implementation."
>
  <main class="page" id="main-content">
    <section class="page-intro">
      <p class="eyebrow">Direct Contact</p>
      <h1>Contact</h1>
      <p class="muted">
        A short project summary by email is enough to discuss scope, priorities, and a realistic
        implementation path.
      </p>
    </section>
    <Contact />
    <WorkingPrinciples />
  </main>
</BaseLayout>
