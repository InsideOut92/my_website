---
import BaseLayout from '../layouts/BaseLayout.astro';
import Skills from '../components/Skills.astro';
---
<BaseLayout
  title="Skills"
  description="Technologiefokus und Arbeitsweise von Patrick Scharf für Integration, Datenverarbeitung und stabile Weiterentwicklung bestehender Systeme."
>
  <main class="page" id="main-content">
    <section class="page-intro">
      <p class="eyebrow">Technischer Fokus</p>
      <h1>Skills für belastbare Integrationen</h1>
      <p class="muted">
        Von API-Anbindung bis Datenqualität: die Schwerpunkte sind auf produktive, wartbare
        Lösungen ausgerichtet.
      </p>
    </section>

    <Skills />
  </main>
</BaseLayout>
