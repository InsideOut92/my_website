---
import BaseLayout from "../layouts/BaseLayout.astro";

const lastUpdated = "17.05.2026";
---

<BaseLayout
  title="Impressum"
  description="Impressum mit Anbieterkennzeichnung für diesen privaten Webauftritt."
>
  <main class="page" id="main-content">
    <section class="page-intro">
      <p class="eyebrow">Rechtliche Angaben</p>
      <h1>Impressum</h1>
      <p class="muted">
        Anbieterkennzeichnung für diesen privaten Webauftritt.
      </p>
    </section>

    <section class="card legal-card">
      <h2>1. Anbieter dieser Website</h2>
      <address>
        Patrick Scharf<br />
        Am Liedlein 3b<br />
        97222 Rimpar<br />
        Deutschland
      </address>
    </section>

    <section class="card legal-card">
      <h2>2. Kontakt</h2>
      <p>
        E-Mail: <a href="mailto:Softwareentwickler@tutamail.com"
          >Softwareentwickler@tutamail.com</a>
      </p>
    </section>

    <section class="card legal-card">
      <h2>3. Umsatzsteuer-ID</h2>
      <p>
        Umsatzsteuer-Identifikationsnummer gemäß Paragraph 27a
        Umsatzsteuergesetz: nicht vorhanden.
      </p>
      <p>
        Wirtschafts-Identifikationsnummer gemäß Paragraph 139c AO: nicht
        vorhanden.
      </p>
    </section>

    <section class="card legal-card">
      <h2>4. Inhaltlich verantwortlich</h2>
      <p>
        Verantwortlich gemäß Paragraph 18 Absatz 2 Medienstaatsvertrag (MStV):
      </p>
      <address>
        Patrick Scharf<br />
        Am Liedlein 3b<br />
        97222 Rimpar
      </address>
    </section>

    <p class="muted legal-meta">Stand dieser Seite: {lastUpdated}</p>
  </main>
</BaseLayout>
