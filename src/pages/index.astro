---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import Skills from "../components/Skills.astro";
import Projects from "../components/Projects.astro";
import Contact from "../components/Contact.astro";
import BlogHighlights from "../components/BlogHighlights.astro";
import ServiceProfile from "../components/ServiceProfile.astro";
import RecruiterSnapshot from "../components/RecruiterSnapshot.astro";
import AboutProfile from "../components/AboutProfile.astro";
import SapTransitionProfile from "../components/SapTransitionProfile.astro";

const structuredData = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Patrick Scharf",
  jobTitle: "Anwendungsentwickler",
  ...(Astro.site ? { url: Astro.site.toString() } : {}),
  email: "mailto:Softwareentwickler@tutamail.com",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Rimpar",
    addressCountry: "DE",
  },
  knowsAbout: [
    "API-Integration",
    "Systemschnittstellen",
    "Datenmapping",
    "Automatisierung",
    "PHP",
    "Python",
    "MySQL",
  ],
};
---

<BaseLayout
  title="Softwareentwicklung für Integration und stabile Datenprozesse"
  description="Integrationsentwicklung mit Lobster Data, stabilen Datenprozessen und strukturiertem Entwicklungspfad in Richtung SAP-nahe Integrationsrollen."
>
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(structuredData)}
  />
  <main class="page" id="main-content">
    <Hero />
    <ServiceProfile />
    <section class="section">
      <div class="section-head">
        <h2>Projektbeispiele im Überblick</h2>
        <a class="btn btn-secondary" href="/projekte/">Alle Projektbeispiele</a>
      </div>
      <p class="muted">
        Die folgenden Beispiele sind im Format Ausgangslage, technischer Ansatz, Betriebseffekt
        und fachliche Relevanz strukturiert.
      </p>
    </section>
    <Projects />
    <BlogHighlights />
    <AboutProfile />
    <SapTransitionProfile />
    <RecruiterSnapshot />
    <Skills />
    <Contact />
  </main>
</BaseLayout>
