---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { blogPostsDe } from "../../data/blog";
import { blogContentDe } from "../../data/blog-content";

export function getStaticPaths() {
  return blogPostsDe.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const articleContent = blogContentDe[post.slug] ?? [];
const structuredData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.title,
  datePublished: post.date,
  dateModified: post.date,
  inLanguage: "de-DE",
  author: {
    "@type": "Person",
    name: "Patrick Scharf",
  },
  publisher: {
    "@type": "Person",
    name: "Patrick Scharf",
  },
  description: post.summary,
  ...(Astro.site
    ? { mainEntityOfPage: new URL(`/blog/${post.slug}`, Astro.site).toString() }
    : {}),
};
---

<BaseLayout title={post.title} description={post.summary}>
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(structuredData)}
  />
  <main class="page" id="main-content">
    <article class="panel article">
      <p class="muted post-meta">
        <time datetime={post.date}>{post.date}</time>
        <span>·</span>
        <span>{post.readingTime}</span>
      </p>
      <h1>{post.title}</h1>
      <p class="lead muted">{post.summary}</p>
      <div class="tag-row">
        {post.tags.map((tag: string) => <span class="tag">{tag}</span>)}
      </div>
      <div class="article-content">
        {articleContent.map((paragraph) => <p>{paragraph}</p>)}
      </div>
      <p class="article-backlink">
        <a href="/blog/">Zurück zur Blog-Übersicht</a>
      </p>
    </article>
  </main>
</BaseLayout>
