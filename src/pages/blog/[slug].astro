---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { blogPostsDe } from '../../data/blog';

type ContentMap = Record<string, string[]>;

const contentBySlug: ContentMap = {
  'api-integrationen-robust-designen': [
    'Viele Integrationsprobleme entstehen nicht durch fehlende Features, sondern durch unklare Fehlerpfade. In produktiven Systemen ist entscheidend, wie sauber Timeouts, Wiederholungen und Teilfehler behandelt werden.',
    'Bewährt haben sich klare technische Verträge: eindeutige Fehlerklassen, idempotente Endpunkte, Retry mit Backoff und aussagekräftige Log-Korrelation. Damit sinken Störzeiten und Ursachen lassen sich schneller eingrenzen.',
    'Zusammen mit Monitoring auf fachlicher Ebene entsteht Stabilität: Nicht nur HTTP-Status beobachten, sondern auch prozessrelevante Kennzahlen wie Erfolgsquote pro Datentyp, Laufzeitverteilung und Rückstau in Warteschlangen.',
  ],
  'datenmapping-ohne-chaos': [
    'Datenmapping wird oft als reine Transformationsaufgabe gesehen. In Wirklichkeit ist es ein Vertrag zwischen Fachprozess und Technik. Sobald dieser Vertrag implizit bleibt, steigen Fehlerquote und Nacharbeit.',
    'Hilfreich sind drei Ebenen: strukturelle Validierung, fachliche Plausibilität und technische Durchsetzbarkeit. Jede Ebene benötigt nachvollziehbare Fehlermeldungen, damit Operations und Fachseite schnell reagieren können.',
    'In Projekten zahlt sich eine versionierte Mapping-Spezifikation aus. Sie macht Änderungen transparent und reduziert Reibung zwischen beteiligten Teams, besonders bei mehreren Quellsystemen.',
  ],
  'legacy-modernisieren-ohne-risiko': [
    'Bei Legacy-Systemen ist das größte Risiko selten die Technik selbst, sondern unkontrollierte Eingriffe unter Zeitdruck. Ein tragfähiger Ansatz trennt Stabilisierung, Transparenz und Funktionsausbau sauber voneinander.',
    'Startpunkt ist Messbarkeit: Welche Teile verursachen reale Störungen, welche Workflows sind geschäftskritisch, wo liegen harte Abhängigkeiten? Erst dann lohnt gezieltes Refactoring mit kleinen, reversiblen Schritten.',
    'Wer früh auf Testabdeckung für kritische Pfade, saubere Deploy-Routinen und nachvollziehbare Change-Logs setzt, reduziert Betriebsrisiko deutlich und gewinnt gleichzeitig Entwicklungsgeschwindigkeit zurück.',
  ],
};

export function getStaticPaths() {
  return blogPostsDe.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const articleContent = contentBySlug[post.slug] ?? [];
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.title,
  datePublished: post.date,
  dateModified: post.date,
  inLanguage: 'de-DE',
  author: {
    '@type': 'Person',
    name: 'Patrick Scharf',
  },
  publisher: {
    '@type': 'Person',
    name: 'Patrick Scharf',
  },
  description: post.summary,
  ...(Astro.site ? { mainEntityOfPage: new URL(`/blog/${post.slug}`, Astro.site).toString() } : {}),
};
---
<BaseLayout title={post.title} description={post.summary}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  <main class="page" id="main-content">
    <article class="panel article">
      <p class="muted post-meta">
        <time datetime={post.date}>{post.date}</time>
        <span>·</span>
        <span>{post.readingTime}</span>
      </p>
      <h1>{post.title}</h1>
      <p class="lead muted">{post.summary}</p>
      <div class="tag-row">
        {post.tags.map((tag: string) => <span class="tag">{tag}</span>)}
      </div>
      <div class="article-content">
        {articleContent.map((paragraph) => <p>{paragraph}</p>)}
      </div>
      <p class="article-backlink">
        <a href="/blog">Zurück zur Blog-Übersicht</a>
      </p>
    </article>
  </main>
</BaseLayout>
