---
import '../styles/global.css';
import {
  getAlternatePaths,
  getLocaleFromPath,
  getNavLinks,
  normalizePath,
  type Locale,
} from '../utils/i18n';

const {
  title = "Portfolio",
  description = "Schnittstellenentwicklung, API-Integration und stabile Datenprozesse für Unternehmen.",
  locale: localeProp,
  robots = 'index,follow',
} = Astro.props;

const currentPath = normalizePath(Astro.url.pathname);
const locale: Locale = localeProp ?? getLocaleFromPath(currentPath);
const siteName = "Patrick Scharf - Software Development";
const pageTitle = title.includes("|") ? title : `${title} | ${siteName}`;
const canonicalUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : undefined;
const ogImageUrl = Astro.site ? new URL('/og-image.svg', Astro.site).toString() : undefined;

const navLinks = getNavLinks(locale);
const otherLocale: Locale = locale === 'de' ? 'en' : 'de';
const alternates = getAlternatePaths(currentPath);
const localeSwitchHref = alternates
  ? alternates[otherLocale]
  : otherLocale === 'en'
    ? '/en'
    : '/';
const localeSwitchLabel = otherLocale.toUpperCase();
const localeSwitchAriaLabel =
  locale === 'de' ? 'Switch to English version' : 'Zur deutschen Version wechseln';

const alternateDeUrl = Astro.site && alternates ? new URL(alternates.de, Astro.site).toString() : undefined;
const alternateEnUrl = Astro.site && alternates ? new URL(alternates.en, Astro.site).toString() : undefined;
const xDefaultUrl = Astro.site && alternates ? new URL('/', Astro.site).toString() : undefined;

const htmlLang = locale;
const ogLocale = locale === 'de' ? 'de_DE' : 'en_US';
const skipLabel = locale === 'de' ? 'Zum Inhalt springen' : 'Skip to content';
const navAriaLabel = locale === 'de' ? 'Hauptnavigation' : 'Main navigation';

const brandHref = locale === 'de' ? '/' : '/en';
const footerLinks = locale === 'de'
  ? [
      { href: '/kontakt/', label: 'Kontakt' },
      { href: '/datenschutz/', label: 'Datenschutz' },
      { href: '/impressum/', label: 'Impressum' },
    ]
  : [
      { href: '/en/contact/', label: 'Contact' },
      { href: '/en/privacy/', label: 'Privacy' },
      { href: '/en/imprint/', label: 'Legal Notice' },
    ];
---
<!DOCTYPE html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Patrick Scharf" />
    <meta name="robots" content={robots} />
    <meta name="theme-color" content="#0f1a2a" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    {alternateDeUrl && <link rel="alternate" hreflang="de" href={alternateDeUrl} />}
    {alternateEnUrl && <link rel="alternate" hreflang="en" href={alternateEnUrl} />}
    {xDefaultUrl && <link rel="alternate" hreflang="x-default" href={xDefaultUrl} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="manifest" href="/site.webmanifest" />
    <script is:inline>
      (() => {
        try {
          const normalize = (path) => (path.length > 1 && path.endsWith('/') ? path.slice(0, -1) : path || '/');
          const pathname = normalize(window.location.pathname);
          const isEnglishPath = pathname === '/en' || pathname.startsWith('/en/');
          const preferenceKey = 'preferred-locale';
          const setPreference = (value) => localStorage.setItem(preferenceKey, value);

          document.addEventListener(
            'click',
            (event) => {
              const rawTarget = event.target;
              const elementTarget =
                rawTarget instanceof Element
                  ? rawTarget
                  : rawTarget instanceof Node
                    ? rawTarget.parentElement
                    : null;

              if (!elementTarget) {
                return;
              }

              const switchLink = elementTarget.closest('a.locale-switch');
              if (!(switchLink instanceof HTMLAnchorElement)) {
                return;
              }

              const targetLocale = (switchLink.getAttribute('lang') || '').toLowerCase();
              if (targetLocale === 'de' || targetLocale === 'en') {
                setPreference(targetLocale);
              }
            },
            { capture: true }
          );

          if (isEnglishPath) {
            setPreference('en');
            return;
          }

          if (pathname !== '/') {
            setPreference('de');
            return;
          }

          const stored = localStorage.getItem(preferenceKey);
          const browserLanguage = (navigator.language || '').toLowerCase();
          const preferEnglish = stored ? stored === 'en' : browserLanguage.startsWith('en');

          if (preferEnglish) {
            window.location.replace('/en');
          }
        } catch {}
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main-content">{skipLabel}</a>
    <div class="container">
      <header class="header">
        <a class="brand" href={brandHref}>P.S. - Software Development</a>
        <nav class="nav" aria-label={navAriaLabel}>
          {
            navLinks.map((link) => (
              <a
                href={link.href}
                class={normalizePath(link.href) === currentPath ? 'active' : undefined}
                aria-current={normalizePath(link.href) === currentPath ? 'page' : undefined}
              >
                {link.label}
              </a>
            ))
          }
          <a class="locale-switch" href={localeSwitchHref} lang={otherLocale} aria-label={localeSwitchAriaLabel}>
            {localeSwitchLabel}
          </a>
        </nav>
      </header>
      <slot />
      <footer class="footer">
        <span>&copy; {new Date().getFullYear()} Patrick Scharf</span>
        <div class="footer-links">
          {footerLinks.map((link) => <a href={link.href}>{link.label}</a>)}
        </div>
      </footer>
    </div>
  </body>
</html>
